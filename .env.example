# Supabase project — Settings → API in the dashboard.
# Leave unset to run without auth (the app skips sign-in entirely).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase service-role key — Settings → API in the dashboard. SERVER-ONLY:
# no VITE_ prefix, never bundled to the browser. Used by api/ functions to
# write billing state (profiles.plan etc.) bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — https://dashboard.stripe.com/apikeys (use test-mode keys locally).
STRIPE_SECRET_KEY=
# https://dashboard.stripe.com/webhooks — created after `stripe listen` or a
# deployed webhook endpoint; see docs/PRICING.md for local testing.
STRIPE_WEBHOOK_SECRET=
# Price IDs from the Plus/Studio Products in the Stripe dashboard
# (Products → pricing per docs/PRICING.md: Plus $4.99/mo, Studio $19.99/mo).
STRIPE_PRICE_PLUS=
STRIPE_PRICE_STUDIO=
